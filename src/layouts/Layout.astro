---
import type { Lang } from "@/i18n/ui";
import { getCV } from "@/data/cv";
import "@/styles/global.css";

interface Props {
	title: string;
	description: string;
	lang: Lang;
}

const { title, description, lang } = Astro.props;

const site = "https://maxflow.ink";
const alternates = {
	es: `${site}/`,
	en: `${site}/en/`,
} as const;

// Absolute, per-page canonical URL. Falls back to the locale root when
// Astro.url is unavailable (e.g. during certain build phases).
const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? site).href;
const ogImage = new URL("/me.webp", Astro.site ?? site).href;

const ogLocale = lang === "es" ? "es_ES" : "en_US";
const ogLocaleAlternate = lang === "es" ? "en_US" : "es_ES";

// --- JSON-LD Person schema, locale-aware, built from CV data ---
const { basics, education, languages } = getCV(lang);
const personSchema = {
	"@context": "https://schema.org",
	"@type": "Person",
	name: basics.name,
	jobTitle: basics.label,
	description: basics.summary,
	url: canonicalURL,
	image: ogImage,
	email: `mailto:${basics.email}`,
	telephone: basics.phone,
	sameAs: basics.profiles.map((p) => p.url),
	address: {
		"@type": "PostalAddress",
		addressLocality: basics.location.city,
		addressRegion: basics.location.region,
		addressCountry: basics.location.countryCode,
	},
	alumniOf: education.map((e) => ({
		"@type": "CollegeOrUniversity",
		name: e.institution,
		url: e.url,
	})),
	knowsLanguage: languages.map((l) => l.language),
};
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />

		{/* Canonical + hreflang */}
		<link rel="canonical" href={canonicalURL} />
		<link rel="alternate" hreflang="es" href={alternates.es} />
		<link rel="alternate" hreflang="en" href={alternates.en} />
		<link rel="alternate" hreflang="x-default" href={alternates.es} />

		<title>{title}</title>

		{/* Open Graph */}
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={ogImage} />
		<meta property="og:image:alt" content={basics.name} />
		<meta property="og:site_name" content={basics.name} />
		<meta property="og:locale" content={ogLocale} />
		<meta property="og:locale:alternate" content={ogLocaleAlternate} />

		{/* Twitter Card */}
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImage} />

		{/* JSON-LD structured data (schema.org Person) */}
		<script
			is:inline
			type="application/ld+json"
			set:html={JSON.stringify(personSchema)}
		/>

		{/* No-flash theme script: set data-theme before first paint. */}
		<script is:inline>
			(() => {
				try {
					const stored = localStorage.getItem("theme");
					const theme =
						stored === "dark" || stored === "light"
							? stored
							: window.matchMedia("(prefers-color-scheme: dark)").matches
								? "dark"
								: "light";
					document.documentElement.dataset.theme = theme;
				} catch (e) {
					document.documentElement.dataset.theme = "light";
				}
			})();
		</script>
	</head>
	<body>
		<a class="skip-link no-print" href="#main-content">
			<slot name="skip-link">Skip to main content</slot>
		</a>
		<slot />
	</body>
</html>
