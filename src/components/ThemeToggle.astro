---
import type { Lang } from "@/i18n/ui";
import { getUI } from "@/i18n/ui";

interface Props {
	lang: Lang;
}

const { lang } = Astro.props;
const ui = getUI(lang);
---

<button
	id="theme-toggle"
	type="button"
	class="theme-toggle no-print"
	aria-label={ui.themeToggle.label}
	title={ui.themeToggle.label}
	aria-pressed="false"
>
	<svg
		class="icon-sun"
		width="18"
		height="18"
		viewBox="0 0 24 24"
		fill="none"
		stroke="currentColor"
		stroke-width="2"
		stroke-linecap="round"
		stroke-linejoin="round"
		aria-hidden="true"
	>
		<circle cx="12" cy="12" r="4"></circle>
		<path
			d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"
		></path>
	</svg>
	<svg
		class="icon-moon"
		width="18"
		height="18"
		viewBox="0 0 24 24"
		fill="none"
		stroke="currentColor"
		stroke-width="2"
		stroke-linecap="round"
		stroke-linejoin="round"
		aria-hidden="true"
	>
		<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
	</svg>
</button>

<script>
	const toggle = document.getElementById("theme-toggle");
	// Reflect the resolved theme (set pre-paint by the no-flash script)
	// onto aria-pressed: pressed === dark mode active.
	const syncPressed = () => {
		toggle?.setAttribute(
			"aria-pressed",
			document.documentElement.dataset.theme === "dark" ? "true" : "false",
		);
	};
	syncPressed();
	toggle?.addEventListener("click", () => {
		const current = document.documentElement.dataset.theme;
		const next = current === "dark" ? "light" : "dark";
		document.documentElement.dataset.theme = next;
		syncPressed();
		try {
			localStorage.setItem("theme", next);
		} catch (e) {
			/* localStorage unavailable — ignore */
		}
	});
</script>

<style>
	.theme-toggle {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 44px;
		height: 44px;
		padding: 0;
		background: transparent;
		border: none;
		color: var(--text-secondary);
		cursor: pointer;
		transition: color 0.2s var(--ease-out);
	}
	.theme-toggle:hover {
		color: var(--text);
	}
	/* Show the icon for the action the click performs:
	   light mode -> show moon (switch to dark); dark mode -> show sun. */
	.icon-moon {
		display: block;
	}
	.icon-sun {
		display: none;
	}
	:global([data-theme="dark"]) .icon-moon {
		display: none;
	}
	:global([data-theme="dark"]) .icon-sun {
		display: block;
	}
</style>
