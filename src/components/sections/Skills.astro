---
import type { Lang } from "@/i18n/ui";
import { getUI } from "@/i18n/ui";
import { getCV } from "@/data/cv";
import Section from "../Section.astro";

interface Props {
	lang: Lang;
}

const { lang } = Astro.props;
const ui = getUI(lang);
const { skills } = getCV(lang);

/* The CV data stores `level` localized (Experto/Avanzado/... or
   Expert/Advanced/...). Map each localized value back to a stable
   key so groups render in a fixed order with localized sub-labels. */
type LevelKey = "expert" | "advanced" | "intermediate" | "basic";

const LEVEL_ALIASES: Record<string, LevelKey> = {
	experto: "expert",
	expert: "expert",
	avanzado: "advanced",
	advanced: "advanced",
	intermedio: "intermediate",
	intermediate: "intermediate",
	básico: "basic",
	basico: "basic",
	basic: "basic",
};

const LEVEL_ORDER: LevelKey[] = ["expert", "advanced", "intermediate", "basic"];

const groups = LEVEL_ORDER.map((key) => ({
	key,
	label: ui.skillLevels[key],
	skills: skills.filter(
		(s) => LEVEL_ALIASES[s.level.trim().toLowerCase()] === key,
	),
})).filter((g) => g.skills.length > 0);
---

<Section title={ui.sections.skills}>
	<div class="groups">
		{
			groups.map((group) => (
				<div class="group">
					<h3 class="group-label font-mono">{group.label}</h3>
					<ul>
						{group.skills.map((skill) => (
							<li class="badge font-mono">{skill.name}</li>
						))}
					</ul>
				</div>
			))
		}
	</div>
</Section>

<style>
	.groups {
		display: flex;
		flex-direction: column;
		gap: var(--space-4);
	}
	.group {
		display: flex;
		flex-direction: column;
		gap: var(--space-2);
	}
	.group-label {
		font-size: var(--text-xs);
		font-weight: 500;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--text-secondary);
	}
	ul {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-2);
	}
	.badge {
		padding: 4px 10px;
		font-size: var(--text-xs);
		color: var(--text);
		background: transparent;
		border: 1px solid var(--text);
		border-radius: var(--radius-sm);
		transition:
			background-color 0.2s var(--ease-out),
			color 0.2s var(--ease-out);
	}
	.badge:hover {
		background: var(--text);
		color: var(--bg);
	}
</style>
