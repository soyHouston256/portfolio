---
import type { Lang } from "@/i18n/ui";
import { getUI } from "@/i18n/ui";
import { getCV } from "@/data/cv";
import Section from "../Section.astro";

interface Props {
	lang: Lang;
}

const { lang } = Astro.props;
const ui = getUI(lang);
const { education } = getCV(lang);
---

<Section title={ui.sections.education}>
	<ul>
		{
			education.map(({ institution, url, area, studyType, startDate, endDate }) => {
				const startyear = new Date(startDate).getFullYear();
				const endyear =
					endDate !== null && endDate !== "" ? new Date(endDate).getFullYear() : ui.present;
				const years = `${startyear} - ${endyear}`;
				return (
					<li>
						<article>
							<header>
								<div>
									<h3>
										<a href={url} target="_blank" rel="noopener noreferrer">
											{institution}
										</a>
									</h3>
									<h4>{area}</h4>
								</div>
								<time class="font-mono">{years}</time>
							</header>
							<p>{studyType}</p>
						</article>
					</li>
				);
			})
		}
	</ul>
</Section>

<style>
	ul {
		display: flex;
		flex-direction: column;
		gap: var(--space-3);
	}
	article {
		display: flex;
		flex-direction: column;
		gap: var(--space-2);
		padding: var(--space-3);
		background: var(--surface);
		border: 1px solid var(--border);
		border-radius: var(--radius-md);
		transition: border-color 0.2s var(--ease-out);
	}
	article:hover {
		border-color: var(--accent);
	}
	header {
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: var(--space-3);
	}
	h3 {
		font-size: var(--text-md);
		font-weight: 600;
		color: var(--text);
	}
	h3 a {
		transition: color 0.2s var(--ease-out);
	}
	h3 a:hover {
		color: var(--accent);
	}
	h4 {
		font-size: var(--text-base);
		font-weight: 400;
		color: var(--text-secondary);
	}
	time {
		flex-shrink: 0;
		font-size: var(--text-xs);
		color: var(--text-secondary);
		white-space: nowrap;
	}
</style>
