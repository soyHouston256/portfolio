---
import type { Lang } from "@/i18n/ui";
import { getUI } from "@/i18n/ui";
import { getCV } from "@/data/cv";
import Section from "../Section.astro";

interface Props {
	lang: Lang;
}

const { lang } = Astro.props;
const ui = getUI(lang);
const { projects } = getCV(lang);

type Badge = { label: string; url?: string };
type Project = (typeof projects)[number] & { badges?: Badge[] };
const projectList = projects as Project[];
---

<Section title={ui.sections.projects}>
	<ul>
		{
			projectList.map(({ name, description, url, highlights, github, isActive, badges }) => {
				return (
					<li>
						<article>
							<header>
								<h3>
									{url ? (
										<a
											href={url.startsWith("http") ? url : `https://${url}`}
											title={ui.projectsLabels.seeProject(name)}
											target="_blank"
											rel="noopener noreferrer"
										>
											{name}
										</a>
									) : (
										<span>{name}</span>
									)}
									{isActive && (
										<>
											<span class="status-dot" aria-hidden="true" />
											<span class="sr-only">{ui.projectsLabels.active}</span>
										</>
									)}
								</h3>
								{badges && badges.length > 0 && (
									<div class="awards">
										{badges.map((badge) => {
											const Icon = (
												<svg
													class="award-icon"
													viewBox="0 0 24 24"
													width="12"
													height="12"
													fill="none"
													stroke="currentColor"
													stroke-width="2"
													stroke-linecap="round"
													stroke-linejoin="round"
													aria-hidden="true"
												>
													<path d="M8 21h8M12 17v4M7 4h10v5a5 5 0 0 1-10 0V4Z" />
													<path d="M17 5h2a2 2 0 0 1 0 4h-2M7 5H5a2 2 0 0 0 0 4h2" />
												</svg>
											);
											return badge.url ? (
												<a
													class="award-badge"
													href={badge.url}
													title={badge.label}
													aria-label={badge.label}
													target="_blank"
													rel="noopener noreferrer"
												>
													{Icon}
													<span>{badge.label}</span>
												</a>
											) : (
												<span class="award-badge" title={badge.label}>
													{Icon}
													<span>{badge.label}</span>
												</span>
											);
										})}
									</div>
								)}
								{github && (
									<a
										class="repo font-mono"
										href={github.startsWith("http") ? github : `https://${github}`}
										title={`${ui.projectsLabels.repository}: ${name}`}
										aria-label={`${ui.projectsLabels.repository}: ${name}`}
										target="_blank"
										rel="noopener noreferrer"
									>
										{ui.projectsLabels.repository}
									</a>
								)}
							</header>
							<p>{description}</p>
							{highlights && highlights.length > 0 && (
								<footer>
									{highlights.map((highlight) => (
										<span class="badge font-mono">{highlight}</span>
									))}
								</footer>
							)}
						</article>
					</li>
				);
			})
		}
	</ul>
</Section>

<style>
	ul {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
		gap: var(--space-3);
	}
	article {
		display: flex;
		flex-direction: column;
		gap: var(--space-3);
		height: 100%;
		padding: 20px;
		background: var(--surface);
		border: 1px solid var(--border);
		border-radius: var(--radius-md);
		transition: border-color 0.2s var(--ease-out);
	}
	article:hover {
		border-color: var(--accent);
	}
	header {
		display: flex;
		flex-direction: column;
		gap: var(--space-1);
	}
	h3 {
		display: flex;
		align-items: center;
		gap: var(--space-2);
		font-size: var(--text-lg);
		font-weight: 600;
		color: var(--text);
	}
	h3 a {
		transition: color 0.2s var(--ease-out);
	}
	h3 a:hover {
		color: var(--accent);
	}
	.status-dot {
		width: 7px;
		height: 7px;
		border-radius: var(--radius-full);
		background: #22c55e;
	}
	.repo {
		font-size: var(--text-xs);
		color: var(--text-secondary);
		transition: color 0.2s var(--ease-out);
	}
	.repo:hover {
		color: var(--accent);
	}
	.awards {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-1);
		margin-top: var(--space-1);
	}
	.award-badge {
		display: inline-flex;
		align-items: center;
		gap: 5px;
		padding: 3px 9px;
		font-size: var(--text-xs);
		font-weight: 500;
		color: var(--accent);
		background: color-mix(in srgb, var(--accent) 12%, transparent);
		border: 1px solid color-mix(in srgb, var(--accent) 45%, transparent);
		border-radius: var(--radius-full);
		transition:
			background-color 0.2s var(--ease-out),
			border-color 0.2s var(--ease-out);
	}
	.award-badge:hover {
		background: color-mix(in srgb, var(--accent) 22%, transparent);
		border-color: var(--accent);
	}
	.award-badge:focus-visible {
		outline: 2px solid var(--accent);
		outline-offset: 2px;
	}
	.award-icon {
		flex-shrink: 0;
	}
	p {
		font-size: var(--text-sm);
		line-height: 1.55;
	}
	footer {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-1);
		margin-top: auto;
	}
	.badge {
		padding: 3px 8px;
		font-size: var(--text-xs);
		color: var(--text);
		background: transparent;
		border: 1px solid var(--text);
		border-radius: var(--radius-sm);
		transition:
			background-color 0.2s var(--ease-out),
			color 0.2s var(--ease-out);
	}
	.badge:hover {
		background: var(--text);
		color: var(--bg);
	}
</style>
