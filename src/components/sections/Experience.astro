---
import type { Lang } from "@/i18n/ui";
import { getUI } from "@/i18n/ui";
import { getCV } from "@/data/cv";
import Section from "../Section.astro";

interface Props {
	lang: Lang;
}

const { lang } = Astro.props;
const ui = getUI(lang);
const { work } = getCV(lang);

// Sort work entries in reverse chronological order (most recent first).
const sortedWork = [...work].sort(
	(a, b) => new Date(b.startDate).getTime() - new Date(a.startDate).getTime()
);
---

<Section title={ui.sections.experience}>
	<ul>
		{
			sortedWork.map(({ name, position, startDate, endDate, summary, highlights }) => {
				const startyear = new Date(startDate).getFullYear();
				const endyear =
					endDate !== null && endDate !== "" ? new Date(endDate).getFullYear() : ui.present;
				const years = `${startyear} - ${endyear}`;
				return (
					<li>
						<article>
							<header>
								<div>
									<h3>{name}</h3>
									<h4>{position}</h4>
								</div>
								<time class="font-mono">{years}</time>
							</header>
							<p>{summary}</p>
							{highlights && highlights.length > 0 && (
								<ul class="highlights">
									{highlights.map((highlight) => (
										<li>{highlight}</li>
									))}
								</ul>
							)}
						</article>
					</li>
				);
			})
		}
	</ul>
</Section>

<style>
	ul {
		display: flex;
		flex-direction: column;
		gap: var(--space-3);
	}
	article {
		display: flex;
		flex-direction: column;
		gap: var(--space-2);
		padding: var(--space-3);
		background: var(--surface);
		border: 1px solid var(--border);
		border-radius: var(--radius-md);
		transition: border-color 0.2s var(--ease-out);
	}
	article:hover {
		border-color: var(--accent);
	}
	header {
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: var(--space-3);
	}
	h3 {
		font-size: var(--text-md);
		font-weight: 600;
		color: var(--text);
	}
	h4 {
		font-size: var(--text-base);
		font-weight: 400;
		color: var(--text-secondary);
	}
	time {
		flex-shrink: 0;
		font-size: var(--text-xs);
		color: var(--text-secondary);
		white-space: nowrap;
	}
	.highlights {
		display: flex;
		flex-direction: column;
		gap: var(--space-1);
		margin-top: var(--space-1);
	}
	.highlights li {
		position: relative;
		padding-left: var(--space-3);
		font-size: var(--text-base);
		line-height: 1.55;
		color: var(--text-secondary);
	}
	.highlights li::before {
		content: "";
		position: absolute;
		left: 0;
		top: 0.62em;
		width: 4px;
		height: 4px;
		border-radius: var(--radius-full);
		background: var(--accent);
	}
</style>
