---
interface Props {
	title?: string;
}

const { title } = Astro.props;
---

<section>
	{title && <h2 class="section-label">{title}</h2>}
	<slot />
</section>

<style>
	section {
		display: flex;
		flex-direction: column;
		gap: var(--space-3);
	}
	/* .section-label carries its own bottom margin; the flex gap
	   already supplies 16px so collapse the duplicate. */
	section > :global(.section-label) {
		margin-bottom: 0;
	}
</style>
